<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Caja Musical IoT 🎼"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnConectar"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Conectar a Caja"
        android:textSize="16sp"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona una canción:"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerCanciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:minHeight="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnReproducir"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Play"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#2196F3" />

        <Button
            android:id="@+id/btnPausa"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Pausa"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="4dp"
            android:backgroundTint="#FF9800" />

        <Button
            android:id="@+id/btnDetener"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Stop"
            android:layout_marginStart="4dp"
            android:backgroundTint="#F44336" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        android:padding="10dp"
        android:background="#15000000">

        <TextView
            android:id="@+id/txtProgreso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progreso: 0%"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="6dp" />

        <ProgressBar
            android:id="@+id/progressCancion"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtVelocidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Velocidad: 1.0x"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBajarVelocidad"
            android:layout_width="60dp"
            android:layout_height="48dp"
            android:text="-"
            android:textSize="18sp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#757575" />

        <Button
            android:id="@+id/btnSubirVelocidad"
            android:layout_width="60dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="18sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#757575" />
    </LinearLayout>

</LinearLayout>